{
  "info": {
    "name": "Genoguevara API Collection",
    "description": "Complete Postman collection for routes under src/routes + app health routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "rootUrl", "value": "http://localhost:5000" },
    { "key": "baseUrl", "value": "{{rootUrl}}/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "fullName", "value": "Admin User" },
    { "key": "email", "value": "admin@example.com" },
    { "key": "password", "value": "StrongPass123!" },
    { "key": "newPassword", "value": "NewStrongPass123!" },
    { "key": "phoneNumber", "value": "+8801700000000" },
    { "key": "userRole", "value": "Admin" },
    { "key": "profileImagePath", "value": "" },
    { "key": "scriptureId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Root Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{rootUrl}}/"
          }
        },
        {
          "name": "API v1 Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"{{fullName}}\",\n  \"email\": \"{{email}}\",\n  \"role\": \"{{userRole}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.accessToken) pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "if (json?.data?.refreshToken) pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "if (json?.data?.user?.email) pm.collectionVariables.set('email', json.data.user.email);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/send-otp"
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"otp\": \"1234\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/verify-otp"
          }
        },
        {
          "name": "Set New Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"newPassword\": \"{{newPassword}}\",\n  \"confirmPassword\": \"{{newPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/set-new-password"
          }
        },
        {
          "name": "Change Password (Auth Required)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"{{password}}\",\n  \"newPassword\": \"{{newPassword}}\",\n  \"confirmPassword\": \"{{newPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/change-password"
          }
        },
        {
          "name": "Refresh Token (cookie required)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Cookie", "value": "refreshToken={{refreshToken}}" }
            ],
            "description": "Uses refreshToken cookie set by Login. Keep requests on same domain in Postman to preserve cookies.",
            "url": "{{baseUrl}}/auth/refresh-token"
          }
        },
        {
          "name": "Logout (cookie required)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Cookie", "value": "refreshToken={{refreshToken}}" }
            ],
            "description": "Uses refreshToken cookie.",
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Users (Auth Required)",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/users/me"
          }
        },
        {
          "name": "Update My Profile (multipart)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "description": "Send as form-data. Leave `profileImage` empty if you only want to update text fields.",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "fullName", "value": "{{fullName}}", "type": "text" },
                { "key": "phoneNumber", "value": "{{phoneNumber}}", "type": "text" },
                { "key": "password", "value": "{{newPassword}}", "type": "text" },
                { "key": "profileImage", "type": "file", "src": "{{profileImagePath}}" }
              ]
            },
            "url": "{{baseUrl}}/users/me"
          }
        }
      ]
    },
    {
      "name": "Scriptures (Auth Required)",
      "item": [
        {
          "name": "Create Scripture",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?._id) pm.collectionVariables.set('scriptureId', json.data._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"author\": \"Anonymous\",\n  \"title\": \"Daily Reflection\",\n  \"content\": \"One day at a time.\",\n  \"mode\": \"Dr. Bob\",\n  \"timeOfDay\": \"Morning\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/scriptures"
          }
        },
        {
          "name": "Get All Scriptures",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/scriptures?page=1&limit=10&sort=-createdAt&search=reflection&mode=Dr.%20Bob&timeOfDay=Morning"
          }
        },
        {
          "name": "Get Scripture Stats",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/scriptures/stats"
          }
        },
        {
          "name": "Get Recent Scriptures",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/scriptures/recent"
          }
        },
        {
          "name": "Get Scripture By ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/scriptures/{{scriptureId}}"
          }
        },
        {
          "name": "Update Scripture",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Reflection\",\n  \"content\": \"Progress not perfection.\",\n  \"mode\": \"Big Book Thumper\",\n  \"timeOfDay\": \"Night\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/scriptures/{{scriptureId}}"
          }
        },
        {
          "name": "Delete Scripture",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/scriptures/{{scriptureId}}"
          }
        }
      ]
    },
    {
      "name": "Common About (Auth Required)",
      "item": [
        {
          "name": "Create Or Update About",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"about\": \"This is the about content.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/common/about"
          }
        },
        {
          "name": "Get About",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/common/about"
          }
        },
        {
          "name": "Update About",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"about\": \"Updated about content.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/common/about"
          }
        }
      ]
    }
  ]
}
